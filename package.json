{
  "name": "mcp-sentinel",
  "version": "0.1.0",
  "description": "Know what you're installing before you npx it. A security scanner for Model Context Protocol (MCP) servers and client configs.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "scanner",
    "ai-agents",
    "claude",
    "llm-tools"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-sentinel": "dist/cli.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.9"
  }
}
